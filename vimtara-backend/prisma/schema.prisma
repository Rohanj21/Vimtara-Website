datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Role Definition
enum Role {
  ADMIN
  USER
  ASSISTANT
}

// 2. User Architecture
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  companyName    String?
  role           Role      @default(USER)
  
  // Premium Features
  plan           String    @default("BASIC") // BASIC, PREMIUM, PREMIUM_PLUS
  dailyTokens    Int       @default(50)
  
  // Relations
  filings        Filing[]
  threads        Thread[]
  messagesSent   Message[] @relation("Sender")
  createdAt      DateTime  @default(now())
}

// 3. Filing Tracking (MCA, GST, etc.)
model Filing {
  id             String    @id @default(uuid())
  title          String    // e.g., "GSTR-3B Q1", "SPICe+ Part A"
  status         String    @default("PENDING") // PENDING, ACTION_REQUIRED, FILED
  dueDate        DateTime
  
  // Link filing to a specific user/company
  userId         String
  user           User      @relation(fields: [userId], references: [id])
}

// 4. Thread Model to group chats by service
model Thread {
  id             String    @id @default(uuid())
  title          String
  service        String    // e.g., 'GST', 'MCA', 'EPFO'
  status         String    @default("OPEN")
  
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  
  messages       Message[]
  createdAt      DateTime  @default(now())
}

// 5. Message Model
model Message {
  id             String    @id @default(uuid())
  content        String
  hasAttachment  Boolean   @default(false)
  attachmentName String?
  attachmentSize String?
  attachmentData String?
  attachmentTag  String?   // <-- NEW: Stores the document type
  
  threadId       String
  thread         Thread    @relation(fields: [threadId], references: [id])
  
  senderId       String
  sender         User      @relation("Sender", fields: [senderId], references: [id])
  
  createdAt      DateTime  @default(now())
}